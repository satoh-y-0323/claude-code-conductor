{
  "_readme": "auto_allow にパターンを追加すると権限ダイアログなしで自動承認します。settings.json の permissions.allow と同じ書式です。notify_on_auto を false にすると自動承認時の通知を無効にできます。",
  "_accepted_exceptions": {
    "Skill": "Skill ツールは引数を str(tool_input) で照合するため特定スキルに絞る手段がない。Skill は version 管理下の .claude/skills/ を読むだけで外部副作用がないため全許可を許容する。"
  },
  "notify_on_auto": false,
  "auto_allow": [
    "Bash(git status*)",
    "Bash(git log*)",
    "Bash(git diff*)",
    "Bash(git add*)",
    "Bash(git commit*)",
    "Bash(git rev-parse*)",
    "Bash(git stash*)",
    "Bash(git check-ignore*)",
    "Edit(.claude/reports/**)",
    "Edit(.claude/memory/**)",
    "Edit(.claude/agent-memory/**)",
    "Edit(.claude/rules/**)",
    "Edit(.claude/skills/**)",
    "Edit(.claude/settings.json)",
    "Write(.claude/reports/**)",
    "Write(.claude/tmp/**)",
    "Write(.claude/memory/**)",
    "Write(.claude/agent-memory/**)",
    "Write(.claude/rules/**)",
    "Write(.claude/skills/**)",
    "Write(.claude/settings.json)",
    "Bash(git rebase*)",
    "Bash(git merge*)",
    "Bash(git -C*)",
    "Bash(git checkout*)",
    "Bash(grep -rn*)",
    "Bash(rm -f .claude/state/*.flag)",
    "Skill"
  ]
}
