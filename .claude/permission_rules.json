{
  "_readme": "auto_allow にパターンを追加すると権限ダイアログなしで自動承認します。settings.json の permissions.allow と同じ書式です。notify_on_auto を false にすると自動承認時の通知を無効にできます。",
  "notify_on_auto": false,
  "auto_allow": [
    "Bash(git status*)",
    "Bash(git log*)",
    "Bash(git diff*)",
    "Bash(git add*)",
    "Bash(git commit*)",
    "Bash(git rev-parse*)",
    "Bash(git stash*)",
    "Bash(git check-ignore*)",
    "Edit(.claude/reports/**)",
    "Edit(.claude/memory/sessions/**)",
    "Edit(.claude/memory/**)",
    "Edit(.claude/agent-memory/**)",
    "Edit(.claude/rules/**)",
    "Edit(.claude/rules/promoted/**)",
    "Edit(.claude/skills/**)",
    "Edit(.claude/settings.json)",
    "Write(.claude/reports/**)",
    "Write(.claude/reports/archive/**)",
    "Write(.claude/tmp/**)",
    "Write(.claude/memory/**)",
    "Write(.claude/memory/sessions/**)",
    "Write(.claude/agent-memory/**)",
    "Write(.claude/rules/**)",
    "Write(.claude/rules/promoted/**)",
    "Write(.claude/skills/**)",
    "Write(.claude/settings.json)",
    "Edit(/*/.claude/memory/sessions/**)",
    "Write(/*/.claude/reports/**)",
    "Write(/*/.claude/memory/**)",
    "Bash(git rebase*)",
    "Bash(git merge*)",
    "Bash(find /*/.claude/worktrees/**)",
    "Bash(git -C*)",
    "Bash(git checkout*)",
    "Bash(grep -rn*)",
    "Bash(Remove-Item -Path*)",
    "Bash(rm -f*)",
    "Skill"
  ]
}
