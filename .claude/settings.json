{
  "permissions": {
    "allow": [
      "Bash(python .claude/hooks/clear_file_history.py*)",
      "Bash(python .claude/hooks/enable_sandbox.py*)",
      "Bash(python .claude/hooks/stop.py*)",
      "Bash(python .claude/hooks/pre_tool.py*)",
      "Bash(python .claude/hooks/pre_compact.py*)",
      "Bash(python .claude/hooks/restore_session.py*)",
      "Bash(python .claude/hooks/permission_handler.py*)",
      "Bash(python .claude/hooks/validate_skill_change.py*)",
      "Bash(python .claude/hooks/statusline.py*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/clear_file_history.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/enable_sandbox.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_compact.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/restore_session.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/permission_handler.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_skill_change.py\"*)",
      "Bash(python \"$CLAUDE_PROJECT_DIR/.claude/hooks/statusline.py\"*)",
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Edit(.claude/reports/**)",
      "Edit(.claude/memory/sessions/**)",
      "Edit(.claude/memory/**)",
      "Edit(.claude/agent-memory/**)",
      "Edit(.claude/rules/**)",
      "Edit(.claude/rules/promoted/**)",
      "Edit(.claude/skills/**)",
      "Edit(.claude/settings.json)",
      "Write(.claude/reports/**)",
      "Write(.claude/reports/archive/**)",
      "Write(.claude/tmp/**)",
      "Write(.claude/memory/**)",
      "Write(.claude/memory/sessions/**)",
      "Write(.claude/agent-memory/**)",
      "Write(.claude/rules/**)",
      "Write(.claude/rules/promoted/**)",
      "Write(.claude/skills/**)",
      "Write(.claude/settings.json)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git rev-parse*)",
      "WebSearch"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**.env.*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "network": {
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": false,
      "allowedDomains": []
    },
    "enableWeakerNestedSandbox": true
  },
  "statusLine": {
    "type": "command",
    "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/statusline.py\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool.py\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree_guard.py\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree_guard.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_skill_change.py\""
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_tool.py\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_skill_change.py\""
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_tool.py\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/permission_handler.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/select_tier.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/restore_session.py\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/init_c3_db.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_compact.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.py\""
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/consolidate_memory.py\""
          }
        ]
      }
    ]
  }
}
